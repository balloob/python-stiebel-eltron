    @property
    def compressor_starts(self) -> int | None:
        """Total compressor starts, combined from the HI/LOW registers."""
        high = self.compressor_starts_hi
        if high is None:
            return None
        low = self.compressor_starts_low
        return high * 1000 + (low or 0)
